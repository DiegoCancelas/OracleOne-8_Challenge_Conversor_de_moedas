<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechStore - Ofertas Incríveis</title>
    <style>
        /* Estilização Básica */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background-color: #f4f4f9; }
        header { background: #2c3e50; color: white; padding: 1rem; text-align: center; }
        
        .container { display: flex; flex-wrap: wrap; justify-content: center; padding: 20px; }
        
        /* Card de Produto */
        .card {
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            margin: 15px;
            padding: 20px;
            width: 250px;
            text-align: center;
            transition: transform 0.3s;
        }
        .card:hover { transform: translateY(-5px); }
        .card img { max-width: 100%; border-radius: 5px; }
        .card h3 { color: #333; }
        .card p { color: #27ae60; font-weight: bold; font-size: 1.2rem; }
        
        button {
            background-color: #27ae60;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1rem;
        }
        button:hover { background-color: #219150; }

        /* Carrinho */
        #carrinho-info { text-align: center; padding: 10px; background: #ecf0f1; border-top: 2px solid #bdc3c7; }
    </style>
</head>
<body>

<header>
    <h1>TechStore Online</h1>
    <p>As melhores tecnologias a um clique de você!</p>
</header>

<div class="container">
    <div class="card">
        <img src="https://via.placeholder.com/150" alt="Smartphone">
        <h3>Smartphone X</h3>
        <p>R$ 1.200,00</p>
        <button onclick="adicionarAoCarrinho('Smartphone X', 1200)">Comprar</button>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/150" alt="Fone Bluetooth">
        <h3>Fone Bluetooth</h3>
        <p>R$ 250,00</p>
        <button onclick="adicionarAoCarrinho('Fone Bluetooth', 250)">Comprar</button>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/150" alt="Smartwatch">
        <h3>Smartwatch Pro</h3>
        <p>R$ 450,00</p>
        <button onclick="adicionarAoCarrinho('Smartwatch Pro', 450)">Comprar</button>
    </div>
</div>

<div id="carrinho-info">
    <h3>Seu Carrinho</h3>
    <p id="status">Itens: 0 | Total: R$ 0,00</p>
    <button onclick="finalizarCompra()">Finalizar Pedido</button>
</div>

<script>
    // Lógica em JavaScript
    let totalItens = 0;
    let valorTotal = 0;

    function adicionarAoCarrinho(nome, preco) {
        totalItens++;
        valorTotal += preco;

        // Atualiza a interface
        document.getElementById('status').innerText = `Itens: ${totalItens} | Total: R$ ${valorTotal.toFixed(2)}`;
        
        console.log(`Adicionado: ${nome}`);
        alert(`${nome} foi adicionado ao seu carrinho!`);
    }

    function finalizarCompra() {
        if (totalItens === 0) {
            alert("Seu carrinho está vazio!");
        } else {
            alert(`Compra finalizada com sucesso!\nTotal de itens: ${totalItens}\nValor total: R$ ${valorTotal.toFixed(2)}`);
            // Reseta o carrinho
            totalItens = 0;
            valorTotal = 0;
            document.getElementById('status').innerText = `Itens: 0 | Total: R$ 0,00`;
        }
    }
</script>

</body>
</html>
